# Plantilla de server/.env para PRODUCCIÓN (copiar al VPS como /var/www/lumbres/server/.env)
# ⚠️ Nunca commitear el .env real.

PORT=5001
NODE_ENV=production

# MariaDB del VPS (usuario propio creado por lumbres-setup.sh, NO root)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=lumbres
DB_PASSWORD=PON_AQUI_LA_DB_PASS
DB_NAME=biblioteca_personal

# Generar NUEVO para prod:  node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERAR_UNO_NUEVO_NO_REUTILIZAR_EL_DE_DEV
JWT_EXPIRES_IN=7d

# Dominio real (con https)
ALLOWED_ORIGINS=https://DOMINIO,https://www.DOMINIO
APP_URL=https://DOMINIO

# Email (opcional; si falta, la app lo omite sin romper)
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Lumbres <no-reply@DOMINIO>

# Stripe — TEST para la puesta en marcha; claves LIVE solo al lanzar de verdad
STRIPE_SECRET_KEY=
# Webhook de producción: crear endpoint https://DOMINIO/api/subscriptions/webhook
# en el Dashboard de Stripe (o por API) y pegar aquí su signing secret:
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PREMIUM_MES=
STRIPE_PRICE_PREMIUM_ANO=

# Límites de plan (opcionales; defaults en server/middleware/plan.js)
# FREE_MAX_BOOKS=5  FREE_MAX_STORAGE_MB=500  PREMIUM_MAX_STORAGE_GB=20
