PORT=5001
NODE_ENV=production

# MySQL Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=biblioteca_personal

# JWT Authentication — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_64_byte_hex_string
JWT_EXPIRES_IN=7d

# CORS — comma-separated list of frontend origins allowed to call this API
ALLOWED_ORIGINS=https://your-frontend-domain.com
